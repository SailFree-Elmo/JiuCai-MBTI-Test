/* app.wxss - 全局样式 */

/* CSS变量定义 */
page {
  --color-primary: #07C160;
  --color-primary-dark: #06ad55;
  --color-primary-light: #0fdb6e;
  --color-gold: #F5A623;
  --color-gold-light: #ffc857;
  --color-bg-dark: #0f0f23;
  --color-bg-card: #1a1a2e;
  --color-bg-card-light: #222240;
  --color-text-primary: #ffffff;
  --color-text-secondary: #a0a0b8;
  --color-text-muted: #6c6c80;
  --color-border: #2a2a45;
  --color-red: #ff4757;
  --color-green-light: #7bed9f;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  background-color: var(--color-bg-dark);
  color: var(--color-text-primary);
  min-height: 100vh;
  overflow-x: hidden;
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

/* 通用卡片样式 */
.card {
  background: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 40rpx;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid var(--color-border);
}

/* 安全区域 */
.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* 页面切换动画 */
.page-enter {
  animation: pageEnter 0.3s ease-out forwards;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateX(60rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 按钮通用 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  color: #ffffff;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 80rpx;
  text-align: center;
  line-height: 1.5;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-gold {
  background: linear-gradient(135deg, var(--color-gold), #e8941e);
  color: #1a1a2e;
  border: none;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 24rpx 80rpx;
  text-align: center;
  line-height: 1.5;
  box-shadow: 0 8rpx 24rpx rgba(245, 166, 35, 0.3);
}

.btn-gold::after {
  border: none;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}
