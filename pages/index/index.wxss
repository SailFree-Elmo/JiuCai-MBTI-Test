/* pages/index/index.wxss - 首页样式 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 60rpx 40rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0f0f23 0%, #1a2a1a 50%, #0f0f23 100%);
  position: relative;
  overflow: hidden;
}

/* 顶部装饰飘叶 */
.top-decoration {
  position: relative;
  width: 100%;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.leaf {
  position: absolute;
  font-size: 48rpx;
  opacity: 0.6;
  animation: float 3s ease-in-out infinite;
}

.leaf-1 {
  left: 10%;
  animation-delay: 0s;
}

.leaf-2 {
  left: 45%;
  animation-delay: 1s;
}

.leaf-3 {
  right: 10%;
  animation-delay: 2s;
}

@keyframes float {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-20rpx) rotate(10deg);
  }
}

/* 主标题区域 */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  margin-bottom: 50rpx;
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

.main-title {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title-line {
  font-size: 72rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 8rpx;
  line-height: 1.3;
}

.title-line.accent {
  color: var(--color-primary);
  text-shadow: 0 0 30rpx rgba(7, 193, 96, 0.4);
}

.subtitle {
  font-size: 36rpx;
  color: var(--color-gold);
  margin-top: 20rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
}

/* 特色卡片 */
.feature-card {
  background: rgba(7, 193, 96, 0.08);
  border: 1rpx solid rgba(7, 193, 96, 0.2);
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
}

.feature-emoji {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.feature-text {
  font-size: 30rpx;
  color: var(--color-text-primary);
}

.feature-divider {
  height: 1rpx;
  background: rgba(7, 193, 96, 0.15);
  margin: 0 20rpx;
}

/* 名言区域 */
.quote-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.quote-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  font-style: italic;
}

/* 按钮区域 */
.btn-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-bottom: 40rpx;
}

.btn-start {
  width: 560rpx;
  height: 100rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(7, 193, 96, 0.4);
  border: none;
  position: relative;
  overflow: hidden;
}

.btn-start::after {
  border: none;
}

.btn-start::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(
    45deg,
    transparent 40%,
    rgba(255, 255, 255, 0.15) 50%,
    transparent 60%
  );
  animation: shimmer 3s infinite;
}

@keyframes shimmer {
  0% {
    transform: translateX(-100%) rotate(0deg);
  }
  100% {
    transform: translateX(100%) rotate(0deg);
  }
}

.btn-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.btn-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 16rpx;
}

/* 底部装饰 */
.bottom-decoration {
  margin-top: auto;
  padding-bottom: 40rpx;
}

.bottom-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  letter-spacing: 2rpx;
}

/* 背景装饰粒子 */
.container::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 400rpx;
  height: 400rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(7, 193, 96, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

.container::after {
  content: '';
  position: absolute;
  bottom: 100rpx;
  left: -150rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(245, 166, 35, 0.06) 0%, transparent 70%);
  pointer-events: none;
}
