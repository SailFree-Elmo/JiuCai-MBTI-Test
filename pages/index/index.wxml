<!-- pages/index/index.wxml - 首页模板 -->
<view class="container {{animationClass}}">
  <!-- 顶部装饰 -->
  <view class="top-decoration">
    <view class="leaf leaf-1">🌱</view>
    <view class="leaf leaf-2">🥬</view>
    <view class="leaf leaf-3">💹</view>
  </view>

  <!-- 主标题区域 -->
  <view class="hero-section">
    <view class="logo-icon">🌿</view>
    <view class="main-title">
      <text class="title-line">韭菜MBTI</text>
      <text class="title-line accent">人格分析</text>
    </view>
    <view class="subtitle">测测你是哪种韭菜？</view>
  </view>

  <!-- 韭菜特色描述卡片 -->
  <view class="feature-card card">
    <view class="feature-item">
      <text class="feature-emoji">📊</text>
      <text class="feature-text">16道趣味投资场景题</text>
    </view>
    <view class="feature-divider"></view>
    <view class="feature-item">
      <text class="feature-emoji">🎭</text>
      <text class="feature-text">16种韭菜人格精准解读</text>
    </view>
    <view class="feature-divider"></view>
    <view class="feature-item">
      <text class="feature-emoji">🤝</text>
      <text class="feature-text">分享给股友一起测</text>
    </view>
  </view>

  <!-- 名言/趣味语 -->
  <view class="quote-section">
    <text class="quote-text">"每个韭菜都有自己的性格，</text>
    <text class="quote-text">你的投资风格决定了你的韭菜人格"</text>
  </view>

  <!-- 开始按钮 -->
  <view class="btn-area">
    <button class="btn-start" bindtap="startTest">
      <text class="btn-text">🚀 开始测试</text>
    </button>
    <text class="btn-hint">约2分钟出结果</text>
  </view>

  <!-- 底部装饰 -->
  <view class="bottom-decoration">
    <text class="bottom-text">— 纯属娱乐，不构成投资建议 —</text>
  </view>
</view>
