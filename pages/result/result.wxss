/* pages/result/result.wxss - 结果页样式 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 40rpx 32rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #0f0f23 0%, #0d1a0d 50%, #0f0f23 100%);
  position: relative;
  overflow: hidden;
}

/* 庆祝区域 */
.celebration-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
  margin-bottom: 30rpx;
}

.confetti {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  animation: confettiBounce 1s ease-out;
}

@keyframes confettiBounce {
  0% {
    transform: scale(0) rotate(-30deg);
    opacity: 0;
  }
  50% {
    transform: scale(1.3) rotate(10deg);
  }
  100% {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
}

.result-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  letter-spacing: 4rpx;
}

/* MBTI类型大展示 */
.type-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  animation: typeReveal 0.8s ease-out;
}

@keyframes typeReveal {
  0% {
    transform: scale(0.5);
    opacity: 0;
  }
  60% {
    transform: scale(1.1);
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.type-emoji {
  font-size: 120rpx;
  margin-bottom: 16rpx;
}

.type-code {
  font-size: 96rpx;
  font-weight: 900;
  color: var(--color-primary);
  letter-spacing: 16rpx;
  text-shadow: 0 0 40rpx rgba(7, 193, 96, 0.5);
  margin-bottom: 12rpx;
}

.type-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-gold);
  letter-spacing: 4rpx;
}

/* 人格解读卡片 */
.description-card {
  margin-bottom: 24rpx;
  animation: cardSlideUp 0.5s ease-out;
}

.description-text {
  font-size: 30rpx;
  color: var(--color-text-primary);
  line-height: 1.8;
}

/* 维度得分展示 */
.dimensions-card {
  margin-bottom: 24rpx;
  animation: cardSlideUp 0.5s ease-out 0.1s both;
}

.dimension-row {
  margin-bottom: 28rpx;
}

.dimension-row:last-child {
  margin-bottom: 0;
}

.dimension-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.dim-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.dim-label-active {
  color: var(--color-text-primary);
  font-weight: 600;
}

.dimension-bar-container {
  position: relative;
}

.dimension-bar-bg {
  width: 100%;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 8rpx;
  overflow: hidden;
}

.dimension-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 1s ease-out;
}

.bar-green {
  background: linear-gradient(90deg, var(--color-primary), var(--color-primary-light));
}

.bar-gold {
  background: linear-gradient(90deg, var(--color-gold), var(--color-gold-light));
}

.dimension-percent {
  display: flex;
  justify-content: space-between;
  margin-top: 6rpx;
}

.percent-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

/* 优劣势展示 */
.traits-card {
  margin-bottom: 24rpx;
  animation: cardSlideUp 0.5s ease-out 0.2s both;
}

.traits-row {
  display: flex;
  gap: 24rpx;
}

.traits-col {
  flex: 1;
}

.strengths {
  padding-right: 12rpx;
  border-right: 1rpx solid var(--color-border);
}

.weaknesses {
  padding-left: 12rpx;
}

.trait-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.trait-item:last-child {
  margin-bottom: 0;
}

.trait-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
}

.trait-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.4;
}

/* 投资忠告 */
.advice-card {
  margin-bottom: 24rpx;
  animation: cardSlideUp 0.5s ease-out 0.3s both;
}

.advice-text {
  font-size: 28rpx;
  color: var(--color-gold);
  line-height: 1.8;
  font-style: italic;
}

/* 标签展示 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 40rpx;
  justify-content: center;
  animation: cardSlideUp 0.5s ease-out 0.4s both;
}

.tag-item {
  background: rgba(7, 193, 96, 0.1);
  border: 1rpx solid rgba(7, 193, 96, 0.3);
  border-radius: 24rpx;
  padding: 10rpx 24rpx;
}

.tag-text {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
}

/* 底部按钮区域 */
.bottom-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  margin-bottom: 30rpx;
  animation: cardSlideUp 0.5s ease-out 0.5s both;
}

.btn-share {
  width: 560rpx;
  height: 96rpx;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
  border: none;
}

.btn-share::after {
  border: none;
}

.btn-share-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.btn-retest {
  width: 560rpx;
  height: 96rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid var(--color-border);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-retest::after {
  border: none;
}

.btn-retest-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  letter-spacing: 2rpx;
}

/* 底部声明 */
.footer-notice {
  margin-bottom: 40rpx;
}

.footer-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  letter-spacing: 2rpx;
}

/* 通用卡片头部 */
.card-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

/* 卡片上滑动画 */
@keyframes cardSlideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 背景装饰 */
.container::before {
  content: '';
  position: absolute;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(7, 193, 96, 0.12) 0%, transparent 70%);
  pointer-events: none;
}
